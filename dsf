-- _G.CartiHub* compatibility shims (external code may call these by name)

function populateWeaponSpawner()
	spawnerWeaponList = collectSpawnerWeapons(function(_, _, data)
		return isSpawnerRarity(data)
	end)
	spawnerWeaponByName = {}
	spawnerWeaponNames = {}
	for _, weapon in ipairs(spawnerWeaponList) do
		spawnerWeaponByName[weapon.name] = weapon
		table.insert(spawnerWeaponNames, weapon.name)
	end

	if WeaponBrowserDropdown then
		WeaponBrowserDropdown:Refresh(spawnerWeaponNames, true)
	end

	if RealisticDropdown then
		RealisticDropdown:Refresh(spawnerWeaponNames, true)
	end
end

function populateOfferSpawner()
	offerWeaponList = collectSpawnerWeapons(function(itemId, itemType, data)
		return isOfferSpawnerWeapon(data) and canFakeTradeItem(itemId, itemType)
	end)
	offerWeaponByName = {}
	offerWeaponNames = {}
	for _, weapon in ipairs(offerWeaponList) do
		offerWeaponByName[weapon.name] = weapon
		table.insert(offerWeaponNames, weapon.name)
	end

	if OfferDropdown then
		OfferDropdown:Refresh(offerWeaponNames, true)
	end
end

populateRealisticSpawner = populateWeaponSpawner

function AddWeaponBox(itemId, itemType, weaponName, rarity)
	local name = weaponName or itemId
	if not spawnerWeaponByName[name] then
		spawnerWeaponByName[name] = { itemId = itemId, itemType = itemType, name = name, rarity = rarity }
		table.insert(spawnerWeaponNames, name)

		if WeaponBrowserDropdown then
			WeaponBrowserDropdown:Refresh(spawnerWeaponNames, true)
		end

		if RealisticDropdown then
			RealisticDropdown:Refresh(spawnerWeaponNames, true)
		end
	end
end

