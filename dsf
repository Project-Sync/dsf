function CartiHubTraceFakeAcceptState(reason)
	if not _G.CartiHubDebugFakeTradeAccept then
		return
	end

	local actions = tradeModule.GUI and tradeModule.GUI.Actions
	local accept = actions and actions:FindFirstChild("Accept")
	local actionButton = accept and accept:FindFirstChild("ActionButton")
	local cooldown = accept and accept:FindFirstChild("Cooldown")
	local confirm = accept and accept:FindFirstChild("Confirm")
	local cancel = accept and accept:FindFirstChild("Cancel")
	local addItem = accept and accept:FindFirstChild("AddItem")
	local containerOverlay = accept and accept:FindFirstChild("ClientPlaceholderTradeActionOverlay")
	local actionOverlay = actionButton and actionButton:FindFirstChild("ClientPlaceholderTradeActionOverlay")
	local color = actionButton and actionButton:IsA("GuiObject") and actionButton.BackgroundColor3
	local colorText = color and ("%d,%d,%d"):format(color.R * 255, color.G * 255, color.B * 255) or "nil"

	local signature = table.concat({
		tostring(reason),
		tostring(localAcceptMode),
		tostring(_G.CartiHubFakeTradeActive),
		tostring(accept and accept.Visible),
		tostring(actionButton and actionButton.Visible),
		tostring(actionButton and actionButton:IsA("GuiButton") and actionButton.Active),
		tostring(actionButton and actionButton:IsA("GuiButton") and actionButton.AutoButtonColor),
		tostring(actionButton and actionButton:IsA("GuiObject") and actionButton.BackgroundTransparency),
		colorText,
		tostring(cooldown and cooldown.Visible),
		tostring(confirm and confirm.Visible),
		tostring(cancel and cancel.Visible),
		tostring(addItem and addItem.Visible),
		tostring(containerOverlay and containerOverlay.Visible),
		tostring(actionOverlay and actionOverlay.Visible),
	}, "|")

	if signature == _G.CartiHubLastAcceptTrace then
		return
	end

	_G.CartiHubLastAcceptTrace = signature
	warn("[Carti Hub][AcceptDebug] " .. signature)
end

