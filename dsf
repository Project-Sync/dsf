-- Debug logging: writes to <executor workspace>/mm2_weapon_debug.log (Potassium: this ends up
-- at C:\Users\<you>\AppData\Local\Potassium\workspace\mm2_weapon_debug.log). Dedupes by `key` so
-- the equip-visual watcher loop (runs every 0.35s) doesn't spam the file with repeats -- a line
-- is only written when the message for that key actually changes.
local DEBUG_LOG_FILE = "mm2_weapon_debug.log"
local debugLogBuffer = {}
local debugLogLastForKey = {}

local function debugLog(key, fmt, ...)
	local ok, msg = pcall(string.format, fmt, ...)
	if not ok then
		msg = tostring(fmt)
	end

	if debugLogLastForKey[key] == msg then
		return
	end
	debugLogLastForKey[key] = msg

	local line = ("[%s] %s"):format(os.date("%H:%M:%S"), msg)
	table.insert(debugLogBuffer, line)
	pcall(warn, "[CartiHubDebug] " .. line)

	pcall(function()
		if appendfile then
			appendfile(DEBUG_LOG_FILE, line .. "\n")
		elseif writefile then
			writefile(DEBUG_LOG_FILE, table.concat(debugLogBuffer, "\n") .. "\n")
		end
	end)
end

pcall(function()
