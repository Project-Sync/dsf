local excludedBulkSpawnNames = {
	["???"] = true,
	["chroma???"] = true,
	["bronzeraygun"] = true,
	["goldraygun"] = true,
	["redraygun"] = true,
	["silverraygun"] = true,
	["synthwave"] = true,
